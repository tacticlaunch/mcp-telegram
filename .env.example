# Telegram API credentials (required)
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional overrides
# PORT=                    # pin a port (default: random, persisted to ~/.mcp-telegram/state.json)
# HOST=127.0.0.1
# MCP_TELEGRAM_HOME=       # alternative state/session directory
# LOG_LEVEL=info           # debug | info | warn | error
